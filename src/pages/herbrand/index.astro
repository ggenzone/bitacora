---
import PageLayout from '../../layouts/page.astro';
import BlogPostPreview from "../../components/BlogPostPreview.astro";
import { latestPosts } from "../../utils/content";

const pageTitle = "Herbrand Universe";

const posts = await latestPosts("herbrand");

---
<PageLayout title={pageTitle}>
    <div class="grid grid-cols-1 gap-8 md:grid-cols-1 xl:grid-cols-2">    
        {posts.map(post => 
            <BlogPostPreview post={post} url={`/bitacora/herbrand/${post.id}`} />
        )}
    </div>
</PageLayout>