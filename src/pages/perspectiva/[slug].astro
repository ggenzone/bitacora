---
import MarkdownPostLayout from '../../layouts/post.astro';
import { getCollection, render } from 'astro:content';
import { Debug } from 'astro:components';
import { sidebar } from '../../data/perspectiva-menu.ts';

export async function getStaticPaths() {
  const posts = await getCollection('perspectiva');
  return posts.map(post => ({
    params: { slug: post.id }, props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<MarkdownPostLayout 
  frontmatter={post.data}
  headings={post.rendered.metadata.headings} 
  url={`/bitacora/perspectiva/${post.id}`}
  sidebar={sidebar}
>
  <Content />
</MarkdownPostLayout>
